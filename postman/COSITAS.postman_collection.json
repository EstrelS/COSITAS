{
    "info": {
        "name": "COSITAS API v1 (mínima)",
        "_postman_id": "cositas-minimal",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
        "name": "Auth - Login",
        "request": {
            "method": "POST",
            "header": [
            { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
            "mode": "raw",
            "raw": "{\n  \"email\": \"admin@cositas.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] }
        }
        },
        {
        "name": "Productos - Listar",
        "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/productos", "host": ["{{base_url}}"], "path": ["productos"] }
        }
        },
        {
        "name": "Productos - Crear (protegido)",
        "request": {
            "method": "POST",
            "header": [
            { "key": "Content-Type", "value": "application/json" },
            { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
            "mode": "raw",
            "raw": "{\n  \"nombre\": \"Producto de prueba\",\n  \"precio\": 10.5,\n  \"cantidad_disponible\": 5,\n  \"descripcion\": \"Descripción\",\n  \"id_categoria\": 1,\n  \"fotos\": [\"https://example.com/img.jpg\"]\n}"
            },
            "url": { "raw": "{{base_url}}/productos", "host": ["{{base_url}}"], "path": ["productos"] }
        }
        }
    ],
    "variable": [
        { "key": "base_url", "value": "http://localhost:5000/api/v1" },
        { "key": "token", "value": "" }
    ]
}
